/* 学习中心样式 */
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; }

.study-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
}

.slogan-left, .slogan-right {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 48px;
    font-weight: bold;
    color: #fff;
    writing-mode: vertical-lr;
    letter-spacing: 14px;
    text-shadow: 0 0 20px rgba(255,255,255,0.5), 2px 2px 4px rgba(0,0,0,0.2);
    font-family: "KaiTi", "STKaiti", "Microsoft YaHei", serif;
    padding: 20px 12px;
    border: 3px solid rgba(255,255,255,0.7);
    border-radius: 15px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(5px);
}

.slogan-left {
    left: 20px;
}

.slogan-right {
    right: 20px;
}

/* 装饰元素 */
.deco {
    position: absolute;
    color: rgba(255,255,255,0.6);
    font-size: 24px;
    animation: float 3s ease-in-out infinite;
}

.deco-1 { top: 15%; left: 15%; animation-delay: 0s; }
.deco-2 { top: 20%; right: 15%; animation-delay: 1s; }
.deco-3 { bottom: 20%; left: 10%; animation-delay: 0.5s; }
.deco-4 { bottom: 15%; right: 10%; animation-delay: 1.5s; }

.deco-line {
    position: absolute;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
}

.deco-line-1 { top: 30%; left: 5%; right: 5%; }
.deco-line-2 { bottom: 30%; left: 5%; right: 5%; }

@keyframes float {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50% { transform: translateY(-10px); opacity: 1; }
}

.slogan-left::before {
    content: "☀";
    display: block;
    font-size: 20px;
    text-align: center;
    margin-bottom: 10px;
}

.slogan-right::before {
    content: "🌙";
    display: block;
    font-size: 20px;
    text-align: center;
    margin-bottom: 10px;
}

@media (max-width: 600px) {
    .slogan-left, .slogan-right {
        font-size: 28px;
        letter-spacing: 8px;
        padding: 10px 8px;
    }
    .slogan-left {
        left: 5px;
    }
    .slogan-right {
        right: 5px;
    }
    .slogan-left::before, .slogan-right::before {
        font-size: 14px;
        margin-bottom: 5px;
    }
}

.study-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    width: 100%;
    max-width: 420px;
    overflow: hidden;
    margin-top: 20px;
}

.alert { margin: 15px 15px 0; padding: 12px 15px; border-radius: 8px; display: flex; align-items: center; gap: 10px; font-size: 14px; }
.alert-danger { background: #ffebee; color: #f44336; }
.alert-warning { background: #fff3e0; color: #ff9800; }
.alert-success { background: #e8f5e9; color: #4caf50; }

.date-header {
    background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    padding: 30px 20px;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
}

.date-main { display: flex; align-items: center; gap: 15px; }
.date-main .day { font-size: 56px; font-weight: bold; line-height: 1; }
.date-info { display: flex; flex-direction: column; }
.year-month { font-size: 18px; font-weight: 500; }
.weekday { font-size: 14px; opacity: 0.9; }

.user-section { display: flex; align-items: center; padding: 20px; border-bottom: 1px solid #f0f0f0; }
.user-avatar img { width: 50px; height: 50px; border-radius: 50%; object-fit: cover; }
.user-details { margin-left: 15px; display: flex; flex-direction: column; }
.user-name { font-size: 18px; font-weight: 600; color: #333; }
.user-role { font-size: 12px; color: #999; }

.status-section { padding: 20px; }

.status-active, .status-idle {
    display: flex; align-items: center; gap: 15px; padding: 20px;
    border-radius: 12px;
}

.status-active { background: #fff3e0; }
.status-idle { background: #f5f5f5; }

.status-icon { font-size: 40px; }
.status-active .status-icon { color: #ff9800; }
.status-idle .status-icon { color: #999; }

.status-text { display: flex; flex-direction: column; }
.status-label { font-size: 18px; font-weight: 600; color: #333; }
.status-time { font-size: 14px; color: #666; margin-top: 5px; }
.status-duration { font-size: 14px; color: #ff9800; margin-top: 5px; font-weight: 600; }

.today-stats { padding: 15px 20px; background: #f0f7f4; margin: 0 20px; border-radius: 10px; }
.today-stats .stat-row { display: flex; justify-content: space-between; font-size: 14px; }
.today-stats .stat-label { color: #666; }
.today-stats .stat-value { color: #11998e; font-weight: 600; }

.duration-section {
    display: flex;
    padding: 20px;
    background: #f8f9fa;
    gap: 20px;
}

.duration-item { flex: 1; text-align: center; }
.duration-label { display: block; font-size: 12px; color: #666; margin-bottom: 5px; }
.duration-value { display: block; font-size: 24px; font-weight: bold; color: #11998e; }
.duration-value.time-range { font-size: 16px; }

.action-section { padding: 20px; }

.btn-study {
    width: 100%;
    padding: 18px;
    border: none;
    border-radius: 12px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.3s;
}

.btn-start {
    background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    color: #fff;
}
.btn-start:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(17, 153, 142, 0.4);
}

.btn-end {
    background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
    color: #fff;
}
.btn-end:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(235, 51, 73, 0.4);
}

.btn-study:disabled { background: #e0e0e0; color: #999; cursor: not-allowed; }
.btn-icon { font-size: 24px; }

.tips-section { padding: 20px; background: #f8f9fa; margin: 0 20px; border-radius: 12px; }
.tips-section h4 { font-size: 14px; color: #333; margin-bottom: 10px; }
.tips-section ul { list-style: none; padding: 0; margin: 0; }
.tips-section li { font-size: 13px; color: #666; margin-bottom: 8px; padding-left: 15px; position: relative; }
.tips-section li::before { content: "•"; position: absolute; left: 0; color: #11998e; }

.footer-links { display: flex; border-top: 1px solid #f0f0f0; }
.footer-links .link-item {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 15px;
    color: #666;
    text-decoration: none;
    font-size: 14px;
}
.footer-links .link-item:first-child { border-right: 1px solid #f0f0f0; }
.footer-links .link-item:hover { background: #f8f9fa; }

.btn { padding: 10px 20px; border: none; border-radius: 6px; font-size: 14px; cursor: pointer; }
.btn-primary { background: #11998e; color: #fff; }
.btn-primary:hover { background: #0f8a80; }

@media (max-width: 480px) {
    .study-card { border-radius: 0; min-height: 100vh; }
    .date-main .day { font-size: 42px; }
    .duration-section { flex-direction: column; gap: 15px; }
}
