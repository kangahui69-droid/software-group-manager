<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>高校软件小组管理系统</display-name>

    <!-- 字符编码过滤器 -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>filter.CharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 权限控制过滤器 -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/member/*</url-pattern>
        <url-pattern>/admin/*</url-pattern>
        <url-pattern>/activity</url-pattern>
        <url-pattern>/activity/*</url-pattern>
        <url-pattern>/news</url-pattern>
        <url-pattern>/news/*</url-pattern>
        <url-pattern>/project</url-pattern>
        <url-pattern>/project/*</url-pattern>
        <url-pattern>/award</url-pattern>
        <url-pattern>/award/*</url-pattern>
        <url-pattern>/recruit</url-pattern>
        <url-pattern>/recruit/*</url-pattern>
        <url-pattern>/study</url-pattern>
        <url-pattern>/study/*</url-pattern>
        <url-pattern>/ai</url-pattern>
        <url-pattern>/ai/*</url-pattern>
    </filter-mapping>

    <!-- 操作日志过滤器 -->
    <filter>
        <filter-name>LoggingFilter</filter-name>
        <filter-class>filter.LoggingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LoggingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 安全过滤器（XSS和CSRF防护） -->
    <filter>
        <filter-name>SecurityFilter</filter-name>
        <filter-class>filter.SecurityFilter</filter-class>
        <init-param>
            <param-name>excludeUrls</param-name>
            <param-value>/login,/logout,/csrf-token</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>SecurityFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 登录Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- 登出Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- 新闻Servlet -->
    <servlet>
        <servlet-name>NewsServlet</servlet-name>
        <servlet-class>servlet.NewsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NewsServlet</servlet-name>
        <url-pattern>/news/*</url-pattern>
    </servlet-mapping>

    <!-- 文件上传Servlet -->
    <servlet>
        <servlet-name>FileUploadServlet</servlet-name>
        <servlet-class>servlet.FileUploadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FileUploadServlet</servlet-name>
        <url-pattern>/upload</url-pattern>
    </servlet-mapping>

    <!-- 文件下载Servlet -->
    <servlet>
        <servlet-name>FileDownloadServlet</servlet-name>
        <servlet-class>servlet.FileDownloadServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FileDownloadServlet</servlet-name>
        <url-pattern>/download/*</url-pattern>
    </servlet-mapping>

    <!-- 统一文件接口Servlet -->
    <servlet>
        <servlet-name>FileStorageServlet</servlet-name>
        <servlet-class>servlet.FileStorageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FileStorageServlet</servlet-name>
        <url-pattern>/file</url-pattern>
    </servlet-mapping>

    <!-- 招新Servlet -->
    <servlet>
        <servlet-name>RecruitServlet</servlet-name>
        <servlet-class>servlet.RecruitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RecruitServlet</servlet-name>
        <url-pattern>/recruit/*</url-pattern>
        <url-pattern>/admin/recruit/*</url-pattern>
    </servlet-mapping>

    <!-- 成员管理Servlet -->
    <servlet>
        <servlet-name>MemberServlet</servlet-name>
        <servlet-class>servlet.MemberServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MemberServlet</servlet-name>
        <url-pattern>/admin/member/*</url-pattern>
    </servlet-mapping>

    <!-- 活动Servlet -->
    <servlet>
        <servlet-name>ActivityServlet</servlet-name>
        <servlet-class>servlet.ActivityServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ActivityServlet</servlet-name>
        <url-pattern>/activity/*</url-pattern>
    </servlet-mapping>

    <!-- 奖项Servlet -->
    <servlet>
        <servlet-name>AwardServlet</servlet-name>
        <servlet-class>servlet.AwardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AwardServlet</servlet-name>
        <url-pattern>/award</url-pattern>
        <url-pattern>/award/*</url-pattern>
    </servlet-mapping>

    <!-- 项目Servlet -->
    <servlet>
        <servlet-name>ProjectServlet</servlet-name>
        <servlet-class>servlet.ProjectServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProjectServlet</servlet-name>
        <url-pattern>/project</url-pattern>
        <url-pattern>/project/*</url-pattern>
    </servlet-mapping>

    <!-- 管理员Servlet -->
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>servlet.AdminServlet</servlet-class>
        <multipart-config>
            <max-file-size>10485760</max-file-size> <!-- 10MB -->
            <max-request-size>20971520</max-request-size> <!-- 20MB -->
            <file-size-threshold>0</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin/api/*</url-pattern>
        <url-pattern>/admin/dashboard</url-pattern>
        <url-pattern>/admin/user</url-pattern>
        <url-pattern>/admin/profile</url-pattern>
    </servlet-mapping>

    <!-- 日志Servlet -->
    <servlet>
        <servlet-name>LogServlet</servlet-name>
        <servlet-class>servlet.LogServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogServlet</servlet-name>
        <url-pattern>/admin/log/*</url-pattern>
    </servlet-mapping>

    <!-- 简历Servlet -->
    <servlet>
        <servlet-name>ResumeServlet</servlet-name>
        <servlet-class>servlet.ResumeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResumeServlet</servlet-name>
        <url-pattern>/resume</url-pattern>
    </servlet-mapping>

    <!-- 简历-教育经历Servlet -->
    <servlet>
        <servlet-name>ResumeEducationServlet</servlet-name>
        <servlet-class>servlet.ResumeEducationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResumeEducationServlet</servlet-name>
        <url-pattern>/resume/education</url-pattern>
    </servlet-mapping>

    <!-- 简历-技能特长Servlet -->
    <servlet>
        <servlet-name>ResumeSkillServlet</servlet-name>
        <servlet-class>servlet.ResumeSkillServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResumeSkillServlet</servlet-name>
        <url-pattern>/resume/skill</url-pattern>
    </servlet-mapping>

    <!-- 简历-项目经历Servlet -->
    <servlet>
        <servlet-name>ResumeProjectServlet</servlet-name>
        <servlet-class>servlet.ResumeProjectServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResumeProjectServlet</servlet-name>
        <url-pattern>/resume/project</url-pattern>
    </servlet-mapping>

    <!-- 简历-获奖情况Servlet -->
    <servlet>
        <servlet-name>ResumeAwardServlet</servlet-name>
        <servlet-class>servlet.ResumeAwardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResumeAwardServlet</servlet-name>
        <url-pattern>/resume/award</url-pattern>
    </servlet-mapping>

    <!-- AI助手Servlet -->
    <servlet>
        <servlet-name>AIServlet</servlet-name>
        <servlet-class>servlet.AIServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AIServlet</servlet-name>
        <url-pattern>/ai</url-pattern>
    </servlet-mapping>

    <!-- 用户资料Servlet -->
    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>servlet.ProfileServlet</servlet-class>
        <multipart-config>
            <max-file-size>10485760</max-file-size>
            <max-request-size>20971520</max-request-size>
            <file-size-threshold>0</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/member/profile/*</url-pattern>
    </servlet-mapping>

    <!-- AI助手Servlet -->
    <servlet>
        <servlet-name>AIServlet</servlet-name>
        <servlet-class>servlet.AIServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AIServlet</servlet-name>
        <url-pattern>/ai</url-pattern>
        <url-pattern>/ai/*</url-pattern>
    </servlet-mapping>

    <!-- 默认首页 -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- 会话超时设置（30分钟） -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
